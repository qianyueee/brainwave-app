# Web アプリと同じ Supabase プロジェクトの情報（Next.js の NEXT_PUBLIC_* と同じ値）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# アプリで使っているアカウント（スマホ側と同じアカウントでログインする）
BRIDGE_EMAIL=you@example.com
BRIDGE_PASSWORD=your-password

# BrainLink Pro のシリアルポート
#   Windows: COM3 など（Bluetooth 設定 → その他のオプション → COM ポートで確認）
#   macOS:   /dev/cu.BrainLink_Pro など
#   Linux:   /dev/rfcomm0 など
EEG_PORT=COM3
EEG_BAUD=115200
