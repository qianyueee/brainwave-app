# Web アプリと同じ Supabase プロジェクトの情報（既定値が同梱されているので通常は変更不要）
SUPABASE_URL=https://rbuxxosedsmpctylrzxj.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# ペアリングコード（スマホアプリの「マインド」→「リアルタイム」に表示されるコード）
PAIRING_CODE=

# BrainLink Pro のシリアルポート
#   Windows: COM3 など（Bluetooth 設定 → その他のオプション → COM ポートで確認）
#   macOS:   /dev/cu.BrainLink_Pro など
#   Linux:   /dev/rfcomm0 など
EEG_PORT=COM3
EEG_BAUD=115200
